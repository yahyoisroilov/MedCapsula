# Supabase
# 1. Create a free project at https://supabase.com
# 2. Go to Settings > API and copy:
#    - Project URL
#    - anon/public key
#    - service_role key (Settings > API > service_role)
# 3. Fill them in below and rename this file to .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudflare R2 (file storage for lesson images/videos)
# 1. Cloudflare dashboard > R2 > Create bucket (e.g. "medcapsula")
# 2. R2 > Manage API tokens > Create token with "Object Read & Write"
#    -> copy the Access Key ID and Secret Access Key
# 3. Account ID is in the R2 sidebar (or your dashboard URL)
# 4. Bucket > Settings > Public access: enable the r2.dev subdomain
#    (or connect a custom domain) and paste that origin as R2_PUBLIC_URL
# 5. Bucket > Settings > CORS policy: allow PUT from your site's origin
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET=medcapsula
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
